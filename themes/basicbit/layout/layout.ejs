<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    <% if (page.title) { %>
      <%= page.title %> - <%= config.title %>
    <% } else { %>
      <%= config.title %>
    <% } %>
  </title>

  <meta name="description" content="<%= page.description || config.description %>">

  <!-- Preload critical resources -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Google Fonts with font-display: swap for performance -->
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    /* Font display swap - prevent FOIT */
    @font-face {
      font-family: 'Roboto';
      font-display: swap;
    }
    @font-face {
      font-family: 'Noto Sans SC';
      font-display: swap;
    }
  </style>

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="<%- theme.root %>/images/favicon.png">

  <!-- CSS -->
  <link rel="stylesheet" href="<%- theme.root %>/css/style.css">

  <!-- Lunr.js for search - deferred for performance -->
  <script defer src="https://unpkg.com/lunr/lunr.js"></script>

  <!-- AdSense -->
  <% if (theme.adsense.enabled) { %>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= theme.adsense.client %>" crossorigin="anonymous"></script>
  <% } %>

  <!-- Open Graph -->
  <meta property="og:title" content="<%= page.title || config.title %>">
  <meta property="og:description" content="<%= page.description || config.description %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= url %>">
</head>
<body>
  <%- partial('_partial/header') %>

  <main>
    <%- body %>
  </main>

  <%- partial('_partial/footer') %>

  <script src="<%- theme.root %>/js/main.js"></script>
</body>
</html>
