<header class="site-header">
  <div class="header-container">
    <div class="site-logo">
      <a href="<%- url_for('/') %>"><%= config.title %></a>
    </div>

    <nav class="site-nav">
      <ul class="nav-list">
        <li><a href="<%- url_for('/') %>">首页</a></li>
        <li class="dropdown">
          <a href="#" class="dropdown-toggle">分类</a>
          <ul class="dropdown-menu">
            <% site.categories.forEach(function(category) { %>
            <li><a href="<%- url_for('/category/' + category.name) %>"><%= category.name %></a></li>
            <% }); %>
          </ul>
        </li>
        <li><a href="<%- url_for('/tags') %>">标签</a></li>
        <li><a href="<%- url_for('/about') %>">关于</a></li>
      </ul>
    </nav>

    <div class="search-box">
      <form action="<%- url_for('/search') %>" method="get" class="search-form">
        <input type="text" name="q" placeholder="搜索文章..." class="search-input">
        <button type="submit" class="search-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</header>
